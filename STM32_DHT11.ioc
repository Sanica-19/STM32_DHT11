#MicroXplorer Configuration settings - do not modify
File.Version=6

Mcu.Family=STM32F4
Mcu.Name=STM32F401C(D-E)Ux
Mcu.Package=UFQFPN48

# Pins
Mcu.Pin0=PA1
Mcu.Pin1=PB8
Mcu.Pin2=PB9
Mcu.Pin3=PH0 - OSC_IN
Mcu.Pin4=PH1 - OSC_OUT

# GPIO (DHT11)
PA1.Signal=GPIO_Output
PA1.Locked=true

# I2C LCD
PB8.Signal=I2C1_SCL
PB8.Mode=I2C
PB8.Locked=true

PB9.Signal=I2C1_SDA
PB9.Mode=I2C
PB9.Locked=true

# RCC (Clock)
PH0\ -\ OSC_IN.Signal=RCC_OSC_IN
PH0\ -\ OSC_IN.Mode=HSE-External-Oscillator

PH1\ -\ OSC_OUT.Signal=RCC_OSC_OUT
PH1\ -\ OSC_OUT.Mode=HSE-External-Oscillator

# Peripherals
Mcu.IP0=I2C1
Mcu.IP1=TIM2
Mcu.IP2=RCC
Mcu.IP3=SYS
Mcu.IP4=NVIC
Mcu.IPNb=5

# I2C Config
I2C1.ClockSpeed=100000
I2C1.AddressingMode=I2C_ADDRESSINGMODE_7BIT

# Timer Config (for microsecond delay)
TIM2.Prescaler=50-1
TIM2.Period=0xffffffff-1

# Clock Configuration
RCC.PLLSourceVirtual=RCC_PLLSOURCE_HSE
RCC.PLLM=12
RCC.PLLN=96
RCC.PLLP=RCC_PLLP_DIV4
RCC.SYSCLKSource=RCC_SYSCLKSOURCE_PLLCLK
RCC.SYSCLKFreq_VALUE=50000000

# Project Settings
ProjectManager.ProjectName=STM32_DHT11
ProjectManager.ProjectFileName=STM32_DHT11.ioc
ProjectManager.ToolChain=STM32CubeIDE
ProjectManager.MainLocation=Core/Src
ProjectManager.KeepUserCode=true

board=custom
